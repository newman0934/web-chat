# development | production。設為 production 時，下列安全相關值不得沿用預設(否則啟動失敗)。
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://chatweb:chatweb@localhost:5432/chatweb
# 正式環境務必改成隨機長字串(例如 `openssl rand -hex 32`);沿用預設會被 ensure_secure 擋下。
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5000,http://localhost:5001,http://localhost:5002
